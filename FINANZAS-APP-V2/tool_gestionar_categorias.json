    {
      "parameters": {
        "jsCode": "const resposta = $input.first().json;\nif (resposta.action === 'skip') {\n  return [{ json: { mensagem: resposta.mensagem } }];\n}\nif (resposta.success) {\n  if (resposta.categorias) {\n    const lista = resposta.categorias.map(c => `• ${c.nombre} (ID: \\`${c.id}\\`)`).join('\\n');\n    return [{ json: { mensagem: `📂 *Tus Categorías:*\\n\\n${lista || 'No tienes categorías.'}` } }];\n  }\n  return [{ json: { mensagem: resposta.message || '✅ Operación completada.' } }];\n}\nreturn [{ json: { mensagem: `❌ Error: ${resposta.error || 'Error desconocido'}` } }];"
      },
